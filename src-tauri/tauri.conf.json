{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "carliber-tool",
  "version": "3.0.0",
  "identifier": "com.carlibertool.app",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist",
    "beforeDevCommand": "npm run dev:fe",
    "beforeBuildCommand": "npm run build:fe"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "url": "/",
        "title": "carliber-tool",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": false,
        "visible": false,
        "resizable": true,
        "fullscreen": false,
        "center": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "id": "main-tray",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "tooltip": "carliber-tool"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "carliber",
    "category": "DeveloperTool",
    "shortDescription": "omp wrapper + Warp-style block terminal",
    "longDescription": "carliber-tool wraps the omp CLI in a Tauri 2 desktop app with a Warp-style block terminal and multi-agent project configuration."
  }
}
