{
  "appId": "com.claudetool.app",
  "productName": "Claude Tool",
  "directories": {
    "output": "release"
  },
  "win": {
    "target": "nsis",
    "icon": "assets/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  },
  "mac": {
    "target": "dmg",
    "icon": "assets/icon.icns"
  },
  "linux": {
    "target": "AppImage",
    "icon": "assets/icon.png"
  },
  "files": [
    "dist/**/*",
    "electron/**/*",
    "package.json"
  ]
}
